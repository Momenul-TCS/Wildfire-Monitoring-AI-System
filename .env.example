# Copy this file to .env and fill in your values.
# The default values below work out-of-the-box with the local Ollama setup.

# ── LLM / Ollama ─────────────────────────────────────────────────────────────
# Base URL for the LLM API (Ollama or vLLM)
VLLM_BASE_URL=http://localhost:11434/v1

# API key — Ollama accepts any non-empty value; set a real key if using vLLM
VLLM_API_KEY=ollama

# Model to load (Ollama pulls this automatically on first run)
LLM_MODEL_NAME=qwen2.5:7b

# ── Application ───────────────────────────────────────────────────────────────
# Paths to datasets and pre-trained models (defaults work inside Docker)
DATASET_DIR=/app/datasets
MODEL_DIR=/app/models/saved

# Ollama service address (used inside Docker; change for external Ollama)
OLLAMA_HOST=http://ollama:11434
